<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="EventManagementReport"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <property name="ireport.zoom" value="1.0"/>
    <property name="ireport.x" value="0"/>
    <property name="ireport.y" value="0"/>

    <parameter name="ReportTitle" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA["Trip Event Management Report"]]></defaultValueExpression>
    </parameter>
    <parameter name="CompanyName" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA["Gunasekara Travels"]]></defaultValueExpression>
    </parameter>
    <parameter name="GeneratedDate" class="java.lang.String"/>
    <parameter name="TotalEvents" class="java.lang.String"/>
    <parameter name="CompletedEvents" class="java.lang.String"/>
    <parameter name="PendingEvents" class="java.lang.String"/>
    <parameter name="TotalRevenue" class="java.lang.String"/>

    <field name="eventId" class="java.lang.Integer"/>
    <field name="busNumber" class="java.lang.String"/>
    <field name="startLocation" class="java.lang.String"/>
    <field name="endLocation" class="java.lang.String"/>
    <field name="eventValue" class="java.lang.Double"/>
    <field name="eventDate" class="java.time.LocalDate"/>
    <field name="customerName" class="java.lang.String"/>
    <field name="customerContact" class="java.lang.String"/>
    <field name="customerNic" class="java.lang.String"/>
    <field name="eventCompleted" class="java.lang.Boolean"/>

    <variable name="EventCount" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{eventId}]]></variableExpression>
    </variable>

    <variable name="TotalRevenueCalc" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{eventValue}]]></variableExpression>
    </variable>

    <title>
        <band height="140">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="70" backcolor="#3498DB"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="20" y="10" width="742" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[Trip Event Management Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="38" width="742" height="15" forecolor="#E0E0E0"/>
                <textElement textAlignment="Center">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Gunasekara Travels - Bus Event Bookings]]></text>
            </staticText>
            <textField>
                <reportElement x="20" y="53" width="742" height="15" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated on: " + $P{GeneratedDate}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="85" width="190" height="50" backcolor="#E8F5E9"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="90" width="170" height="15" forecolor="#2E7D32"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Events]]></text>
            </staticText>
            <textField>
                <reportElement x="10" y="105" width="170" height="25" forecolor="#1B5E20"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{EventCount}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="198" y="85" width="190" height="50" backcolor="#E3F2FD"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="208" y="90" width="170" height="15" forecolor="#1565C0"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Completed Events]]></text>
            </staticText>
            <textField>
                <reportElement x="208" y="105" width="170" height="25" forecolor="#0D47A1"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CompletedEvents}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="396" y="85" width="190" height="50" backcolor="#FFF3E0"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="406" y="90" width="170" height="15" forecolor="#EF6C00"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Pending Events]]></text>
            </staticText>
            <textField>
                <reportElement x="406" y="105" width="170" height="25" forecolor="#E65100"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{PendingEvents}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="594" y="85" width="188" height="50" backcolor="#F3E5F5"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="604" y="90" width="168" height="15" forecolor="#7B1FA2"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Revenue (Rs.)]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="604" y="105" width="168" height="25" forecolor="#6A1B9A"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TotalRevenueCalc}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement x="0" y="5" width="782" height="25" backcolor="#2980B9"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5" y="8" width="35" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="45" y="8" width="70" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Bus Number]]></text>
            </staticText>
            <staticText>
                <reportElement x="120" y="8" width="95" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Start Location]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="8" width="95" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[End Location]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="8" width="70" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Value (Rs.)]]></text>
            </staticText>
            <staticText>
                <reportElement x="395" y="8" width="70" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="8" width="110" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Customer Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="585" y="8" width="90" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Contact]]></text>
            </staticText>
            <staticText>
                <reportElement x="680" y="8" width="95" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="25" backcolor="#F8F9FA">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement x="5" y="3" width="35" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{eventId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="45" y="3" width="70" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{busNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="3" width="95" height="20"/>
                <textElement textAlignment="Left">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{startLocation}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="3" width="95" height="20"/>
                <textElement textAlignment="Left">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{endLocation}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="320" y="3" width="70" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{eventValue}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="395" y="3" width="70" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{eventDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="3" width="110" height="20"/>
                <textElement textAlignment="Left">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{customerName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="585" y="3" width="90" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{customerContact}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="680" y="3" width="95" height="20" forecolor="#27AE60">
                    <printWhenExpression><![CDATA[$F{eventCompleted}]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["✓ Completed"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="680" y="3" width="95" height="20" forecolor="#E74C3C">
                    <printWhenExpression><![CDATA[!$F{eventCompleted}]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["⏳ Pending"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="24" width="782" height="1" forecolor="#DEE2E6"/>
            </line>
        </band>
    </detail>

    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="3" width="782" height="1" forecolor="#CCCCCC"/>
            </line>
            <textField>
                <reportElement x="10" y="8" width="350" height="20"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated by Gunasekara Travels Bus Management System"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="650" y="8" width="80" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement x="730" y="8" width="52" height="20"/>
                <textElement textAlignment="Left">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[" of " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="60">
            <rectangle>
                <reportElement x="0" y="10" width="782" height="45" backcolor="#ECF0F1"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="400" y="18" width="200" height="20"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Events Listed:]]></text>
            </staticText>
            <textField>
                <reportElement x="610" y="18" width="70" height="20" forecolor="#2980B9"/>
                <textElement textAlignment="Left">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{EventCount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="400" y="33" width="200" height="20"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Revenue (Rs.):]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="610" y="33" width="150" height="20" forecolor="#27AE60"/>
                <textElement textAlignment="Left">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{TotalRevenueCalc}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>