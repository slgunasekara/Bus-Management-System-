<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.busmanagementsystem.controller.MonthlyProfitController">
    <children>
        <AnchorPane id="AnchorPane" fx:id="monthlyProfitContent" minHeight="700.0" minWidth="1280.0" prefHeight="700.0" prefWidth="1280.0" style="-fx-background-color: #f0f2f5;">
            <children>

                <!-- Header Section -->
                <VBox prefHeight="60.0" style="-fx-background-color: linear-gradient(to right, #3498db 0%, #1a5580 50%, #000000 100%); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 3);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15">
                            <children>
                                <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                    <HBox.margin>
                                        <Insets left="25.0" />
                                    </HBox.margin>
                                </ImageView>
                                <VBox spacing="2">
                                    <children>
                                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Monthly Profit Report">
                                            <font>
                                                <Font name="System Bold" size="26.0" />
                                            </font>
                                        </Text>
                                        <Text fill="#e0e0e0" strokeType="OUTSIDE" strokeWidth="0.0" text="View Monthly Income, Expenses and Net Profit">
                                            <font>
                                                <Font size="11.0" />
                                            </font>
                                        </Text>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="backBtn" mnemonicParsing="false" onAction="#back" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-background-radius: 25; -fx-border-color: white; -fx-border-radius: 25; -fx-border-width: 1.5; -fx-cursor: hand;" text="← Back" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                    <HBox.margin>
                                        <Insets right="25.0" />
                                    </HBox.margin>
                                    <padding>
                                        <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                                    </padding>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Month/Year Selection Panel -->
                <AnchorPane prefHeight="120.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="70.0">
                    <children>
                        <Text fill="#1e3c72" layoutX="30.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Select Month &amp; Year">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Text>

                        <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="49.0" prefHeight="57.0" prefWidth="626.0" spacing="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="597.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Month:" textFill="#555555">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="monthComboBox" prefWidth="200.0" promptText="Select Month" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Year:" textFill="#555555">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="yearComboBox" prefWidth="150.0" promptText="Select Year" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" />
                                    </children>
                                </VBox>

                                <VBox alignment="BOTTOM_LEFT" spacing="5.0">
                                    <children>
                                        <Label text=" " />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="generateBtn" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="Generate" textFill="WHITE">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Button>
                                                <Button fx:id="resetBtn" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #95a5a6; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="Reset" textFill="WHITE">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Logo -->
                        <ImageView fitHeight="101.0" fitWidth="198.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 0, 0, 0, 0);" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="10.0">
                            <image>
                                <Image url="@assets/Gunasekara.jpg" />
                            </image>
                        </ImageView>
                        <Button fx:id="printBtn" layoutX="722.0" layoutY="61.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="172.0" style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2980b9); -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="🖨 Print Report" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </AnchorPane>

                <!-- Summary Cards -->
                <HBox prefHeight="88.0" prefWidth="1253.0" spacing="15.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="206.0">
                    <children>
                        <!-- Total Monthly Income Card -->
                        <AnchorPane prefHeight="100.0" style="-fx-background-color: linear-gradient(to bottom right, #2ecc71, #27ae60); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="💰 Total Income">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="totalIncomeText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Total Monthly Expenses Card -->
                        <AnchorPane prefHeight="100.0" style="-fx-background-color: linear-gradient(to bottom right, #e74c3c, #c0392b); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="📊 Total Expenses">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="totalExpensesText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Net Monthly Profit Card -->
                        <AnchorPane prefHeight="100.0" style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2980b9); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="📈 Net Profit">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="netProfitText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Total Trips Card -->
                        <AnchorPane prefHeight="100.0" style="-fx-background-color: linear-gradient(to bottom right, #9b59b6, #8e44ad); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="🚌 Total Trips">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="totalTripsText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="0">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>

                <!-- Relevant Month Profit Breakdown (Top Table - Resizable) -->
                <VBox prefHeight="213.0" prefWidth="1253.0" spacing="15.0" AnchorPane.bottomAnchor="172.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="315.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Text fill="#1e3c72" strokeType="OUTSIDE" strokeWidth="0.0" text="Relevant Month Profit Breakdown">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Text>
                                <Button fx:id="refreshBtn1" mnemonicParsing="false" prefHeight="35.0" prefWidth="38.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔄" textFill="#3498db">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <TableView fx:id="monthlyProfitTableView1" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="monthCol1" minWidth="100.0" prefWidth="120.0" text="Date" />
                                <TableColumn prefWidth="60.0" text="Day" />
                                <TableColumn fx:id="totalIncomeCol1" minWidth="100.0" prefWidth="156.0" text="Total Income (Rs.)" />
                                <TableColumn fx:id="tripExpensesCol1" minWidth="110.0" prefWidth="130.0" text="Trip Expenses (Rs.)" />
                                <TableColumn fx:id="salariesCol1" minWidth="100.0" prefWidth="110.0" text="Salaries (Rs.)" />
                                <TableColumn fx:id="maintenanceCol1" minWidth="110.0" prefWidth="130.0" text="Maintenance (Rs.)" />
                                <TableColumn fx:id="partPurchasesCol1" minWidth="120.0" prefWidth="145.0" text="Part Purchases (Rs.)" />
                                <TableColumn fx:id="otherServicesCol1" minWidth="120.0" prefWidth="140.0" text="Other Services (Rs.)" />
                                <TableColumn fx:id="totalExpensesCol1" minWidth="110.0" prefWidth="130.0" text="Total Expenses (Rs.)" />
                                <TableColumn fx:id="netProfitCol1" minWidth="110.0" prefWidth="130.0" text="Net Profit (Rs.)" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- Monthly Total Profit Breakdown (Bottom Table - Fixed Height) -->
                <VBox prefHeight="132.0" prefWidth="1253.0" spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="14.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Text fill="#1e3c72" strokeType="OUTSIDE" strokeWidth="0.0" text="Monthly Total Profit Breakdown">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Text>
                                <Button fx:id="refreshBtn" mnemonicParsing="false" prefHeight="35.0" prefWidth="59.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔄" textFill="#3498db">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <TableView fx:id="monthlyProfitTableView" prefHeight="170.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);">
                            <columns>
                                <TableColumn fx:id="monthCol" minWidth="100.0" prefWidth="120.0" text="Month" />
                                <TableColumn fx:id="totalIncomeCol" minWidth="100.0" prefWidth="120.0" text="Total Income (Rs.)" />
                                <TableColumn fx:id="tripExpensesCol" minWidth="110.0" prefWidth="130.0" text="Trip Expenses (Rs.)" />
                                <TableColumn fx:id="salariesCol" minWidth="100.0" prefWidth="110.0" text="Salaries (Rs.)" />
                                <TableColumn fx:id="maintenanceCol" minWidth="110.0" prefWidth="130.0" text="Maintenance (Rs.)" />
                                <TableColumn fx:id="partPurchasesCol" minWidth="120.0" prefWidth="145.0" text="Part Purchases (Rs.)" />
                                <TableColumn fx:id="otherServicesCol" minWidth="120.0" prefWidth="140.0" text="Other Services (Rs.)" />
                                <TableColumn fx:id="totalExpensesCol" minWidth="110.0" prefWidth="130.0" text="Total Expenses (Rs.)" />
                                <TableColumn fx:id="netProfitCol" minWidth="110.0" prefWidth="130.0" text="Net Profit (Rs.)" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</StackPane>
