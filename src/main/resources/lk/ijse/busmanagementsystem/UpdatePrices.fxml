<AnchorPane id="AnchorPane" fx:id="statusContent" prefHeight="700.0" prefWidth="1035.0" style="-fx-background-color: linear-gradient(to bottom, #f8f9fa, #e9ecef);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.busmanagementsystem.controller.UpdatePricesController">
    <children>
