<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.busmanagementsystem.controller.DailyProfitController">
    <children>
        <AnchorPane id="AnchorPane" fx:id="dailyProfitContent" minHeight="700.0" minWidth="1280.0" prefHeight="700.0" prefWidth="1280.0" style="-fx-background-color: #f0f2f5;">
            <children>

                <!-- Header Section -->
                <VBox prefHeight="60.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-background-color: linear-gradient(to right, #3498db 0%, #1a5580 50%, #000000 100%); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 3);">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15">
                            <children>
                                <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                    <HBox.margin>
                                        <Insets left="25.0" />
                                    </HBox.margin>
                                </ImageView>
                                <VBox spacing="2">
                                    <children>
                                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Daily Profit Report">
                                            <font>
                                                <Font name="System Bold" size="26.0" />
                                            </font>
                                        </Text>
                                        <Text fill="#e0e0e0" strokeType="OUTSIDE" strokeWidth="0.0" text="View Daily Income, Expenses and Net Profit">
                                            <font>
                                                <Font size="11.0" />
                                            </font>
                                        </Text>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="backBtn" mnemonicParsing="false" onAction="#back" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-background-radius: 25; -fx-border-color: white; -fx-border-radius: 25; -fx-border-width: 1.5; -fx-cursor: hand;" text="← Back" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                    <HBox.margin>
                                        <Insets right="25.0" />
                                    </HBox.margin>
                                    <padding>
                                        <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                                    </padding>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Date Selection Panel -->
                <AnchorPane prefHeight="120.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="70.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                    <children>
                        <Text fill="#1e3c72" layoutX="30.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Select Date Range">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Text>

                        <HBox alignment="CENTER_LEFT" layoutX="19.0" layoutY="49.0" prefHeight="57.0" AnchorPane.leftAnchor="19.0" AnchorPane.rightAnchor="250.0" spacing="20.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="From Date:" textFill="#555555">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <DatePicker fx:id="fromDatePicker" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" />
                                    </children>
                                    <HBox.margin>
                                        <Insets right="20.0" />
                                    </HBox.margin>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="To Date:" textFill="#555555">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <DatePicker fx:id="toDatePicker" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" />
                                    </children>
                                    <HBox.margin>
                                        <Insets right="40.0" />
                                    </HBox.margin>
                                </VBox>

                                <VBox alignment="BOTTOM_LEFT" spacing="5.0">
                                    <children>
                                        <Label text=" " />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="generateBtn" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2ecc71; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="Generate" textFill="WHITE">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets right="20.0" />
                                                    </HBox.margin>
                                                </Button>
                                                <Button fx:id="resetBtn" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #95a5a6; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="Reset" textFill="WHITE">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Logo -->
                        <ImageView fitHeight="101.0" fitWidth="198.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 0, 0, 0, 0);" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="10.0">
                            <image>
                                <Image url="@assets/Gunasekara.jpg" />
                            </image>
                        </ImageView>
                    </children>
                </AnchorPane>

                <!-- Summary Cards -->
                <HBox spacing="15.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="206.0">
                    <children>
                        <!-- Total Daily Income Card -->
                        <AnchorPane prefHeight="100.0" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to bottom right, #2ecc71, #27ae60); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="💰 Total Income">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="totalIncomeText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Total Daily Expenses Card -->
                        <AnchorPane prefHeight="100.0" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to bottom right, #e74c3c, #c0392b); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="📊 Total Expenses">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="totalExpensesText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Net Daily Profit Card -->
                        <AnchorPane prefHeight="100.0" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2980b9); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="📈 Net Profit">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="netProfitText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>

                        <!-- Average Daily Profit Card -->
                        <AnchorPane prefHeight="100.0" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to bottom right, #9b59b6, #8e44ad); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                            <children>
                                <Text fill="WHITE" layoutX="20.0" layoutY="30.0" strokeType="OUTSIDE" strokeWidth="0.0" text="📊 Avg. Daily Profit">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Text>
                                <Text fx:id="avgDailyProfitText" fill="WHITE" layoutX="20.0" layoutY="70.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Rs. 0.00">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>

                <!-- Daily Profit Table -->
                <VBox spacing="15.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="13.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="320.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Text fill="#1e3c72" strokeType="OUTSIDE" strokeWidth="0.0" text="Daily Profit Breakdown">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Text>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="refreshBtn" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔄" textFill="#3498db">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>
                                <Button fx:id="printBtn" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2980b9); -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="🖨 Print Report" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="dailyProfitTableView" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);">
                            <columns>
                                <TableColumn fx:id="dateCol" minWidth="100.0" prefWidth="118.0" text="Date" />
                                <TableColumn fx:id="totalIncomeCol" minWidth="120.0" prefWidth="141.0" text="Total Income (Rs.)" />
                                <TableColumn fx:id="tripExpensesCol" minWidth="120.0" prefWidth="128.0" text="Trip Expenses (Rs.)" />
                                <TableColumn fx:id="salariesCol" minWidth="120.0" prefWidth="128.0" text="Salaries (Rs.)" />
                                <TableColumn fx:id="maintenanceCol" minWidth="120.0" prefWidth="130.0" text="Maintenance (Rs.)" />
                                <TableColumn fx:id="partPurchasesCol" minWidth="130.0" prefWidth="137.0" text="Part Purchases (Rs.)" />
                                <TableColumn fx:id="otherServicesCol" minWidth="140.0" prefWidth="161.0" text="Other Services (Rs.)" />
                                <TableColumn fx:id="totalExpensesCol" minWidth="140.0" prefWidth="156.0" text="Total Expenses (Rs.)" />
                                <TableColumn fx:id="netProfitCol" minWidth="140.0" prefWidth="155.0" text="Net Profit (Rs.)" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </children>
</StackPane>