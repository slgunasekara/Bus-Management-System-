<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="700.0" prefWidth="1035.0" style="-fx-background-color: linear-gradient(to bottom, #f8f9fa, #e9ecef);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.busmanagementsystem.controller.BusManagementToolsController">
    <children>
        <!-- Header -->
        <VBox prefHeight="60.0" prefWidth="1035.0" style="-fx-background-color: linear-gradient(to right, #3498db 0%, #1a5580 50%, #000000 100%); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 3);">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1035.0" spacing="15">
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Bus Management Tools">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Text>
                                <Text fill="#e0e0e0" strokeType="OUTSIDE" strokeWidth="0.0" text="Essential calculators for your business">
                                    <font>
                                        <Font size="11.0" />
                                    </font>
                                </Text>
                            </children>
                            <HBox.margin>
                                <Insets left="25.0" />
                            </HBox.margin>
                        </VBox>
                        <Region prefHeight="60.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#logout" style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-background-radius: 25; -fx-border-color: white; -fx-border-radius: 25; -fx-border-width: 1.5; -fx-cursor: hand;" text="← Logout" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <HBox.margin>
                                <Insets right="25.0" />
                            </HBox.margin>
                            <padding>
                                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                            </padding>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Main Content Area -->
        <HBox layoutX="30.0" layoutY="90.0" prefHeight="580.0" prefWidth="975.0" spacing="20">
            <!-- Left Side - Calculator (Smaller) -->
            <AnchorPane prefHeight="580.0" prefWidth="380.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-background-radius: 20;">
                <children>
                    <VBox alignment="TOP_CENTER" layoutX="10.0" layoutY="10.0" prefHeight="560.0" prefWidth="360.0" spacing="12.0">
                        <children>
                            <AnchorPane prefHeight="50.0" prefWidth="360.0" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6366f1); -fx-background-radius: 15;">
