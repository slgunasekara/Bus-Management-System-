                                    <Button fx:id="btnClear" mnemonicParsing="false" onAction="#handleClear" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #ef4444, #dc2626); -fx-background-radius: 12; -fx-cursor: hand;" text="AC" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <font><Font name="System Bold" size="16.0" /></font>
                                    </Button>
                                    <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDelete" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #f97316, #ea580c); -fx-background-radius: 12; -fx-cursor: hand;" text="DEL" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <font><Font name="System Bold" size="14.0" /></font>
                                    </Button>
                                    <Button fx:id="btnPercent" mnemonicParsing="false" onAction="#handlePercent" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-cursor: hand;" text="\%" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                        <font><Font name="System Bold" size="20.0" /></font>
                                    </Button>
                                    <Button fx:id="btnDivide" mnemonicParsing="false" onAction="#handleDivide" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-cursor: hand;" text="/" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                        <font><Font name="System Bold" size="16.0" /></font>
                                    </Button>

                                    <Button fx:id="btn7" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="7" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn8" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="8" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn9" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="9" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btnMultiply" mnemonicParsing="false" onAction="#handleMultiply" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-cursor: hand;" text="X" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                        <font><Font name="System Bold" size="16.0" /></font>
                                    </Button>

                                    <Button fx:id="btn4" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="4" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn5" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="5" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn6" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="6" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btnMinus" mnemonicParsing="false" onAction="#handleMinus" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-cursor: hand;" text="-" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="2">
                                        <font><Font name="System Bold" size="20.0" /></font>
                                    </Button>

                                    <Button fx:id="btn1" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="1" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn2" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="2" textFill="WHITE" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btn3" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="3" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="3">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btnPlus" mnemonicParsing="false" onAction="#handlePlus" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-cursor: hand;" text="+" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="3">
                                        <font><Font name="System Bold" size="20.0" /></font>
                                    </Button>

                                    <Button fx:id="btn0" mnemonicParsing="false" onAction="#handleNumber" prefHeight="60.0" prefWidth="156.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="0" textFill="WHITE" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Button>
                                    <Button fx:id="btnDot" mnemonicParsing="false" onAction="#handleDot" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #475569, #334155); -fx-background-radius: 12; -fx-cursor: hand;" text="." textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="4">
                                        <font><Font name="System Bold" size="24.0" /></font>
                                    </Button>
                                    <Button fx:id="btnEquals" mnemonicParsing="false" onAction="#handleEquals" prefHeight="60.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(to bottom right, #10b981, #059669); -fx-background-radius: 12; -fx-cursor: hand;" text="=" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="4">
                                        <font><Font name="System Bold" size="20.0" /></font>
                                    </Button>
                                </children>
                            </GridPane>
                        </children>
                    </VBox>
                </children>
            </AnchorPane>

            <!-- Right Side - Other Tools -->
            <VBox prefHeight="580.0" prefWidth="575.0" spacing="15">
                <!-- Fuel Cost Calculator -->
                <AnchorPane prefHeight="180.0" prefWidth="575.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-background-radius: 20;">
                    <children>
                        <VBox layoutX="15.0" layoutY="10.0" prefHeight="160.0" prefWidth="545.0" spacing="10">
                            <children>
                                <Label style="-fx-background-color: linear-gradient(to right, #f97316, #ea580c); -fx-background-radius: 12; -fx-padding: 10;" text="⛽ Fuel Cost Calculator" textFill="WHITE">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <HBox spacing="10">
                                    <children>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Distance (km):" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtDistance" promptText="Enter distance" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Fuel Price (Rs/L):" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtFuelPrice" promptText="Price per liter" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Mileage (km/L):" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtMileage" promptText="Km per liter" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <Button onAction="#calculateFuel" prefWidth="120.0" style="-fx-background-color: linear-gradient(to right, #f97316, #ea580c); -fx-background-radius: 10; -fx-cursor: hand;" text="Calculate" textFill="WHITE">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Button>
                                        <Label fx:id="lblFuelResult" text="Result will appear here" textFill="#64748b">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>

                <!-- Profit Calculator -->
                <AnchorPane prefHeight="180.0" prefWidth="575.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-background-radius: 20;">
                    <children>
                        <VBox layoutX="15.0" layoutY="10.0" prefHeight="160.0" prefWidth="545.0" spacing="10">
                            <children>
                                <Label style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-background-radius: 12; -fx-padding: 10;" text="📊 Trip Profit Calculator" textFill="WHITE">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <HBox spacing="10">
                                    <children>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Revenue (Rs):" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtRevenue" promptText="Total income" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Expenses (Rs):" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtExpenses" promptText="Total costs" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <Button onAction="#calculateProfit" prefWidth="120.0" style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-background-radius: 10; -fx-cursor: hand;" text="Calculate" textFill="WHITE">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Button>
                                        <Label fx:id="lblProfitResult" text="Result will appear here" textFill="#64748b">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>

                <!-- Time Duration Calculator -->
                <AnchorPane prefHeight="180.0" prefWidth="575.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-background-radius: 20;">
                    <children>
                        <VBox layoutX="15.0" layoutY="10.0" prefHeight="160.0" prefWidth="545.0" spacing="10">
                            <children>
                                <Label style="-fx-background-color: linear-gradient(to right, #3b82f6, #2563eb); -fx-background-radius: 12; -fx-padding: 10;" text="⏰ Trip Duration Calculator" textFill="WHITE">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <HBox spacing="10">
                                    <children>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Start Time:" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtStartTime" promptText="HH:MM (24hr)" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="End Time:" textFill="#475569">
                                                    <font><Font name="System Bold" size="11.0" /></font>
                                                </Label>
                                                <TextField fx:id="txtEndTime" promptText="HH:MM (24hr)" style="-fx-background-radius: 8; -fx-border-color: #cbd5e1; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
