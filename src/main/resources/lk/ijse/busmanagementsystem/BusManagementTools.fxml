                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Button>
                                        <Label fx:id="lblTimeResult" text="Result will appear here" textFill="#64748b">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Label>
                                    </children>
