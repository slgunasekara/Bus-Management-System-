                                                <font>
                                                    <Font name="System Bold" size="10.0" />
                                                </font>
                                            </Label>
                                            <TextField fx:id="txtDisplay" alignment="CENTER_RIGHT" editable="false" prefHeight="40.0" prefWidth="330.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold; -fx-border-color: transparent;" text="0" />
                                        </children>
                                    </VBox>
                                </children>
                            </AnchorPane>

