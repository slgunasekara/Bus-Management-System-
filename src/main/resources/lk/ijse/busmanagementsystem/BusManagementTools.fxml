                                    <Label alignment="CENTER" layoutX="0.0" layoutY="0.0" prefHeight="50.0" prefWidth="360.0" text="Calculator" textFill="WHITE">
                                        <font>
                                            <Font name="System Bold" size="20.0" />
                                        </font>
                                    </Label>
                                </children>
                            </AnchorPane>

                            <AnchorPane prefHeight="80.0" prefWidth="360.0" style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #0f172a); -fx-background-radius: 15;">
