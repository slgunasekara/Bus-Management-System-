<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane style="-fx-background-color: linear-gradient(to bottom, #f8f9fa, #e9ecef);"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="lk.ijse.busmanagementsystem.controller.ForgotPasswordController">

    <VBox alignment="CENTER" spacing="20" maxWidth="500"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 50, 0, 0, 8);">

        <padding>
            <Insets top="40" right="50" bottom="40" left="50"/>
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="10">
            <Text text="🔐" style="-fx-font-size: 48px;"/>
            <Text text="Forgot Password?" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #3498db;"/>
            <Text text="Don't worry! Enter your email to reset your password"
                  style="-fx-font-size: 13px; -fx-fill: #6c757d;"
                  textAlignment="CENTER" wrappingWidth="350"/>
        </VBox>

        <Separator prefWidth="200"/>

        <!-- Email Section -->
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Email Address" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #dee2e6; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-padding: 10 15;">
                <Text text="📧" style="-fx-font-size: 20px;"/>
                <TextField fx:id="emailField"
                           promptText="Enter your registered email"
                           style="-fx-background-color: transparent; -fx-border-width: 0;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button fx:id="sendOtpButton"
                    text="Send OTP"
                    onAction="#handleSendOtp"
                    maxWidth="Infinity"
                    style="-fx-background-color: linear-gradient(to right, #3498db, #1a5580); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 12px;"
                    prefHeight="45"/>
        </VBox>

        <!-- OTP Section (Hidden by default) -->
        <VBox fx:id="otpSection" spacing="10" VBox.vgrow="ALWAYS">
            <Separator prefWidth="200"/>
            <Label text="Enter OTP" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #dee2e6; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-padding: 10 15;">
                <Text text="🔢" style="-fx-font-size: 20px;"/>
                <TextField fx:id="otpField"
                           promptText="Enter 6-digit OTP"
                           style="-fx-background-color: transparent; -fx-border-width: 0;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <Text text="⏱️ OTP is valid for 10 minutes"
                  style="-fx-font-size: 12px; -fx-fill: #6c757d;"/>
            <Button fx:id="verifyOtpButton"
                    text="Verify OTP"
                    onAction="#handleVerifyOtp"
                    maxWidth="Infinity"
                    style="-fx-background-color: linear-gradient(to right, #28a745, #218838); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 12px;"
                    prefHeight="45"/>
        </VBox>

        <!-- Password Section (Hidden by default) -->
        <VBox fx:id="passwordSection" spacing="10" VBox.vgrow="ALWAYS">
            <Separator prefWidth="200"/>
            <Label text="New Password" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #dee2e6; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-padding: 10 15;">
                <Text text="🔒" style="-fx-font-size: 20px;"/>
                <PasswordField fx:id="newPasswordField"
                               promptText="Enter new password"
                               style="-fx-background-color: transparent; -fx-border-width: 0;"
                               HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label text="Confirm Password" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #dee2e6; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-padding: 10 15;">
                <Text text="🔐" style="-fx-font-size: 20px;"/>
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm new password"
                               style="-fx-background-color: transparent; -fx-border-width: 0;"
                               HBox.hgrow="ALWAYS"/>
            </HBox>

            <Button fx:id="resetPasswordButton"
                    text="Reset Password"
                    onAction="#handleResetPassword"
                    maxWidth="Infinity"
                    style="-fx-background-color: linear-gradient(to right, #dc3545, #c82333); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 12px;"
                    prefHeight="45"/>
        </VBox>

        <Separator prefWidth="200"/>

        <!-- Back to Login -->
        <HBox alignment="CENTER" spacing="5">
            <Text text="Remember your password?" style="-fx-fill: #6c757d;"/>
            <Hyperlink fx:id="backToLoginLink"
                       text="Back to Login"
                       onAction="#handleBackToLogin"
                       style="-fx-text-fill: #3498db; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>

</StackPane>